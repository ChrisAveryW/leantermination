(format LCTRS)
(theory Reals)
(fun p0 (-> Real Real Real Real Real))
(fun p1 (-> Real Real Real Real Real))
(fun p2 (-> Real Real Real Real Real))
(entrypoint p0)

(rule (p0 A B C D) (p1 A B C D))

(rule
  (p1 A B C D)
  (p2
    (ite (< A B) (+ A (* 0.5 (- B A))) (- A (* 0.25 (- A B))))
    (ite (>= C 0.0)
         (* C (+ 1.0 (/ D (+ (* C C) 1.0))))
         (- 0.0 (* C (- 1.0 (/ D (+ (* C C) 1.0))))))
    (+ (* A A) (* B B) (* C C) (* D D))
    (- (* (- 2.0) A) (* 3.5 B) (- (* 0.1 C)) D))
  :guard (and (distinct A B) (not (= D 0.0))))

(rule
  (p2 A B C D)
  (p1
    (/ (+ A B C D) 4.0)
    (* A B)
    (- C D)
    (ite (> A 0.0) (- D 1.0) (+ D 1.0)))
  :guard (or (< (* A A) 100.0) (> (+ B C) D)))
