(format LCTRS)
(theory Ints)

(fun q0 (-> Int Int))
(fun q1 (-> Int Int))
(fun q2 (-> Int Int))
(fun q3 (-> Int Int))
(fun q4 (-> Int Int))
(fun q5 (-> Int Int))
(fun q6 (-> Int Int))
(fun q7 (-> Int Int))
(fun q8 (-> Int Int))
(fun q9 (-> Int Int))
(fun qF (-> Int Int))

(entrypoint q0)

(rule (q0 X) (q1 (+ X 1)))
(rule (q1 X) (q2 (+ X 1)))
(rule (q2 X) (q3 (+ X 1)))
(rule (q3 X) (q4 (+ X 1)))
(rule (q4 X) (q5 (+ X 1)))
(rule (q5 X) (q6 (+ X 1)))
(rule (q6 X) (q7 (+ X 1)))
(rule (q7 X) (q8 (+ X 1)))
(rule (q8 X) (q9 (+ X 1)))
(rule (q9 X) (qF X) :guard (>= X 100))
(rule (q9 X) (q0 (- X 5)) :guard (< X 100))
